TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=1872856256
TELEGRAM_CONTROL_TOKEN=replace_with_a_long_random_secret
TELEGRAM_CALLBACK_BIND_HOST=127.0.0.1
TELEGRAM_BOT_LOCK_PATH=data/telegram-bot.lock
TELEGRAM_RESULT_POLL_MS=5000
CALLBACK_BASE_URL=http://localhost:8788

# MCP server: loopback-only by default. Set a long random token and send it via the header below on POST /mcp.
IG_APPROVAL_MCP_BIND_HOST=127.0.0.1
IG_APPROVAL_MCP_PORT=8789
IG_APPROVAL_MCP_AUTH_HEADER=x-ig-approval-mcp-token
IG_APPROVAL_MCP_AUTH_TOKEN=replace_with_a_long_random_secret
# Optional trusted-local escape hatch for development only. When true/1, loopback POST /mcp requests can skip the auth header.
IG_APPROVAL_MCP_TRUST_LOCAL_NO_AUTH=false

AUTOMATION_ENABLED=true
DAILY_LIMIT=10
HOURLY_LIMIT=3
WORKER_COOLDOWN_MIN_MS=120000
WORKER_COOLDOWN_MAX_MS=480000
WORKER_WAKE_POLL_MS=1000
WORKER_LAUNCHD_LABEL=com.austincaddell.ig-approval-worker
# Optional debug/compat toggle: set to true/1 to force polling wakeups and skip fs.watch.
WORKER_DISABLE_FS_WATCH=false
